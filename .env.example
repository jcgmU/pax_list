# ════════════════════════════════════════════════════════
# PaxList — Variables de Entorno
# ════════════════════════════════════════════════════════
#
# CICLO DE CONFIGURACIÓN:
# 1. Deploy backend en Railway → obtener URL del servicio
# 2. Poner esa URL en VITE_BACKEND_URL antes de deployar Vercel
# 3. Deploy frontend en Vercel → obtener dominio
# 4. Poner ese dominio en ALLOWED_ORIGINS de Railway → redeploy

# ── FRONTEND (Vercel env vars) ─────────────────────────
# URL del backend desplegado en Railway (sin slash final)
VITE_BACKEND_URL=https://[tu-servicio].up.railway.app

# ── BACKEND (Railway env vars) ─────────────────────────
# Dominio(s) de Vercel autorizados (separados por coma, sin slash final)
ALLOWED_ORIGINS=https://[tu-proyecto].vercel.app

# Tamaño máximo de PDF aceptado (bytes) — default: 25 MB
MAX_FILE_BYTES=26214400

# Timeout de parseo en segundos — default: 20s
PARSE_TIMEOUT_SEC=20
