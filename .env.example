# ── Frontend (Vite) ──────────────────────────────────────
# URL del backend Python (Railway en prod, localhost en dev)
VITE_BACKEND_URL=http://localhost:8000

# API key que coincide con API_KEY del backend
# En dev local puede dejarse vacío si API_KEY no está seteada en el backend
VITE_API_KEY=

# ── Backend (Railway env vars) ────────────────────────────
# Secreto compartido con el frontend. Generar con: openssl rand -hex 32
# Si se deja vacío, el backend no valida la key (solo para desarrollo local)
API_KEY=

# Orígenes permitidos por CORS (dominio exacto de Vercel en prod)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Tamaño máximo del PDF en bytes (default 25MB)
MAX_FILE_BYTES=26214400

# Timeout de parsing en segundos (default 20)
PARSE_TIMEOUT_SEC=20

# ── NOTA DE SEGURIDAD ─────────────────────────────────────
# VITE_API_KEY se incrusta en el bundle JS del cliente y es visible
# en el inspector del navegador. Esto NO es un secreto verdadero desde
# una SPA pública. La defensa real requiere un proxy same-origin en Vercel
# (rewrite /api/* → Railway inyectando la key server-side).
# La API key actual frena scripts triviales; CORS + rate limiting completan la defensa.
